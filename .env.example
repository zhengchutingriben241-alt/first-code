# Set a strong password for blog article access
BLOG_READER_PASSWORD=your-secure-blog-password

# Optional secret used to sign the blog auth cookie.
# If not set, the password value is used as the fallback secret.
BLOG_AUTH_SECRET=your-cookie-signing-secret

# Admin dashboard credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_AUTH_SECRET=your-admin-cookie-signing-secret
ADMIN_OTP_SECRET=your-admin-otp-signing-secret

# Resend API key for email notifications
RESEND_API_KEY=your-resend-api-key
